# MCP Server Configuration
MCP_API_KEY=your-secret-api-key-here
MCP_PORT=8080

# Host to bind the HTTP server to (default: 127.0.0.1 — localhost only for security).
# Set to 0.0.0.0 only when running behind a reverse proxy that handles TLS and auth.
MCP_HOST=

# Server Mode
# "" / "whatsmeow" (default): connect to WhatsApp Web via whatsmeow and sync into
#   a local messages.db (supports sending and live history sync).
# "local": READ-ONLY mode. Serve the native WhatsApp desktop app's database
#   directly (macOS), with no whatsmeow and no separate/copied database. The
#   native database is never written to. Sending and live sync are unavailable.
#   Must run on the same machine as the WhatsApp desktop app (not in Docker).
WHATSAPP_MODE=

# Local mode options (only used when WHATSAPP_MODE=local)
# Path to the native app's ChatStorage.sqlite. Defaults to the standard macOS
# location (~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/).
LOCAL_CHATSTORAGE_PATH=
# Path to LID.sqlite (maps @lid IDs to phone numbers). Defaults to the sibling
# of LOCAL_CHATSTORAGE_PATH if present.
LOCAL_LID_PATH=
# Your own JID or phone number. Defaults to auto-detection from the "Message
# yourself" chat.
WHATSAPP_OWNER_JID=

# Logging Configuration
LOG_LEVEL=INFO

# Timezone Configuration
# Controls how timestamps are displayed in MCP text output. Defaults to UTC.
# Webhook/REST JSON payloads are always emitted in UTC regardless of this.
TIMEZONE=UTC

# Media Download Configuration
# Enable/disable automatic media download when messages arrive
MEDIA_AUTO_DOWNLOAD_ENABLED=true

# Enable/disable automatic media download from HistorySync events
# HistorySync can trigger hundreds of downloads simultaneously causing 403 errors
# Set to false to only download media from new incoming messages
MEDIA_AUTO_DOWNLOAD_FROM_HISTORY=false

# Maximum file size for auto-download in MB (0 = unlimited)
MEDIA_AUTO_DOWNLOAD_MAX_SIZE_MB=10

# Comma-separated list of media types to auto-download
# Options: image, video, audio, document, sticker, ptt, gif
MEDIA_AUTO_DOWNLOAD_TYPES=image,audio,sticker

# Webhook Configuration (optional)
# Primary webhook URL - message events will be sent here automatically
# Leave empty to disable webhooks
WEBHOOK_URL=

# Advanced webhook settings
# Maximum number of delivery retry attempts (default: 3)
WEBHOOK_MAX_RETRIES=3

# HTTP request timeout in seconds (default: 10)
WEBHOOK_TIMEOUT_SECONDS=10

# Number of concurrent webhook delivery workers (default: 3)
WEBHOOK_WORKER_POOL_SIZE=3